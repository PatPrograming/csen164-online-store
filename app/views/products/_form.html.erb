<%= form_with model: @product, local: true do |f| %>
  <% if @product.errors.any? %>
    <div class="error-box">
      <strong><%= pluralize(@product.errors.count, "error") %> prevented saving:</strong>
      <ul>
        <% @product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>
  <div class="field">
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>
  <div class="field">
    <%= f.label :price %>
    <%= f.number_field :price, step: 0.01, min: 0 %>
  </div>
  <div class="field">
    <%= f.label :image_url, "Image URL" %>
    <%= f.text_field :image_url, placeholder: "https://..." %>
  </div>
  <%= f.submit %>
<% end %>
