<% content_for :title, "Your Cart" %>
<h1>Your Cart</h1>

<% if @cart.empty? %>
  <p class="muted">Your cart is empty. <%= link_to "Browse products", root_path %>.</p>
<% else %>
  <div class="card">
    <table>
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Subtotal</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @cart.line_items.includes(:product).each do |item| %>
          <tr>
            <td><%= link_to item.product.name, item.product %></td>
            <td><%= money(item.product.price) %></td>
            <td>
              <%= form_with url: line_item_path(item), method: :patch, local: true,
                    style: "display:flex; gap:0.4rem; align-items:center;" do %>
                <%= number_field_tag :quantity, item.quantity, min: 0, style: "width:70px;" %>
                <%= submit_tag "Update", class: "btn btn-secondary" %>
              <% end %>
            </td>
            <td><%= money(item.total_price) %></td>
            <td>
              <%= button_to "Remove", line_item_path(item), method: :delete, class: "btn btn-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr>
          <th colspan="3" style="text-align:right;">Total</th>
          <th colspan="2"><%= money(@cart.total_price) %></th>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="actions">
    <% if logged_in? %>
      <%= link_to "Proceed to Checkout", new_order_path, class: "btn" %>
    <% else %>
      <%= link_to "Log in to Checkout", login_path, class: "btn" %>
    <% end %>
    <%= button_to "Empty Cart", cart_path, method: :delete, class: "btn btn-secondary" %>
    <%= link_to "Keep Shopping", root_path %>
  </div>
<% end %>
