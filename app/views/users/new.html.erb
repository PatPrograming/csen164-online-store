<% content_for :title, "Sign up" %>
<h1>Create an account</h1>

<div class="form-card">
  <%= form_with model: @user, url: signup_path, local: true do |f| %>
    <% if @user.errors.any? %>
      <div class="error-box">
        <strong><%= pluralize(@user.errors.count, "error") %> prevented sign up:</strong>
        <ul>
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="field">
      <%= f.label :name %>
      <%= f.text_field :name %>
    </div>
    <div class="field">
      <%= f.label :email %>
      <%= f.email_field :email %>
    </div>
    <div class="field">
      <%= f.label :password %>
      <%= f.password_field :password %>
    </div>
    <div class="field">
      <%= f.label :password_confirmation, "Confirm password" %>
      <%= f.password_field :password_confirmation %>
    </div>
    <%= f.submit "Sign up" %>
  <% end %>
  <p class="muted">Already have an account? <%= link_to "Log in", login_path %></p>
</div>
