<div class="page-head">
  <h2 style="margin:0;">Reviews</h2>
  <div class="stars"><%= stars_for(product.average_rating) %></div>
</div>

<% if logged_in? %>
  <% if user_review %>
    <p class="muted">You reviewed this product.
      <%= link_to "Edit your review", edit_product_review_path(product, user_review) %>
    </p>
  <% else %>
    <div class="card" style="margin-bottom:1rem;">
      <h3 style="margin-top:0;">Write a review</h3>
      <%= form_with model: [product, review], local: true do |f| %>
        <% if review.errors.any? %>
          <div class="error-box">
            <ul>
              <% review.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <div class="field">
          <%= f.label :rating %>
          <%= f.select :rating, (1..5).map { |n| ["#{n} star#{'s' if n > 1}", n] },
                { include_blank: "Choose a rating" } %>
        </div>
        <div class="field">
          <%= f.label :comment %>
          <%= f.text_area :comment, placeholder: "Share your thoughts..." %>
        </div>
        <%= f.submit "Post review" %>
      <% end %>
    </div>
  <% end %>
<% else %>
  <p class="muted"><%= link_to "Log in", login_path %> to write a review.</p>
<% end %>

<% if reviews.any? %>
  <% reviews.each do |r| %>
    <div class="review">
      <div class="review-head">
        <strong><%= r.user.name %></strong>
        <span class="stars"><%= "★" * r.rating %><%= "☆" * (5 - r.rating) %></span>
      </div>
      <p><%= simple_format(r.comment) %></p>
      <span class="muted"><%= r.created_at.strftime("%b %d, %Y") %></span>
      <% if logged_in? && r.user_id == current_user.id %>
        <div class="actions">
          <%= link_to "Edit", edit_product_review_path(product, r), class: "btn btn-secondary" %>
          <%= button_to "Delete", product_review_path(product, r), method: :delete,
                class: "btn btn-danger",
                form: { data: { turbo_confirm: "Delete your review?" } } %>
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <p class="muted">No reviews yet. Be the first to review this product!</p>
<% end %>
